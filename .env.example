# Google Earth Engine
# Option 1: Interactive auth (run ee.Authenticate() in Python)
# Option 2: Service account
GEE_SERVICE_ACCOUNT=your-sa@your-project.iam.gserviceaccount.com
GEE_KEY_PATH=./gee-key.json
GEE_PROJECT_ID=your-gee-project-id

# ECMWF Climate Data Store (for ERA5 downloads outside GEE)
CDS_API_KEY=your-cds-api-key
CDS_API_URL=https://cds.climate.copernicus.eu/api/v2

# ACLED conflict data
ACLED_API_KEY=your-acled-api-key
ACLED_EMAIL=your-email@example.com
